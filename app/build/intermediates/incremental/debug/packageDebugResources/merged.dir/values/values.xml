        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>
    <style name="Widget.AccomFind.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/primary_green</item>
        <item name="strokeWidth">1.5dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/primary_green</item>
