<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="@color/card_dark">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="←"
            android:textSize="16sp"
            android:padding="0dp"
            app:cornerRadius="10dp"
            app:backgroundTint="@color/card_darker" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filter Listings"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginEnd="48dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Price Range -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Maximum Price (BWP)"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BWP 300"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <SeekBar
                    android:id="@+id/sbPrice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="5000"
                    android:progress="3500"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BWP 5,000"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPriceValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Max: BWP 3,500"
                android:textColor="@color/primary_green"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginTop="4dp" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- Location Filter -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/chipGaboroneWest"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Gaborone West"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />

                <TextView
                    android:id="@+id/chipBlock8"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Block 8"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipTlokweng"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tlokweng"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />

                <TextView
                    android:id="@+id/chipPhase2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Phase 2"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipPhakalane"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Phakalane"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />

                <TextView
                    android:id="@+id/chipBroadhurst"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Broadhurst"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipBlock6"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Block 6"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />

                <TextView
                    android:id="@+id/chipKgaleView"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kgale View"
                    android:gravity="center"
                    android:padding="10dp"
                    android:layout_margin="4dp"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:background="@drawable/bg_chip_unselected" />
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp" />

            <!-- Availability Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available From (Optional)"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etFilterDate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="e.g. 2024-05-01"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/white"
                android:background="@drawable/bg_input"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginTop="10dp" />

            <!-- Save Preferences Toggle -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Save preferences &amp; enable alerts"
                    android:textColor="@color/white"
                    android:textSize="13sp" />

                <Switch
                    android:id="@+id/switchSavePrefs"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Apply Button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="@color/card_dark">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnApplyFilter"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Apply Filters"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/primary_green" />
    </LinearLayout>

</LinearLayout>
